APP_NAME="Restaurant CRM"
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://YOUR_DOMAIN

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=restaurant_crm
DB_USERNAME=crm_user
DB_PASSWORD=STRONG_PASSWORD_HERE

SESSION_DRIVER=redis
SESSION_LIFETIME=120

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=STRONG_REDIS_PASSWORD_HERE
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=noreply@YOUR_DOMAIN
MAIL_PASSWORD=MAIL_PASSWORD_HERE
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@YOUR_DOMAIN"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=restaurant-crm
REVERB_APP_KEY=CHANGE_THIS_KEY
REVERB_APP_SECRET=CHANGE_THIS_SECRET
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

TELEGRAM_BOT_TOKEN=

# Internal API URL (used by web controllers to call API)
# On Docker: http://nginx, on shared hosting/VPS: same as APP_URL
API_INTERNAL_URL=https://YOUR_DOMAIN
